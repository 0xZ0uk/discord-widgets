{
	"name": "discord-widgets",
	"private": true,
	"workspaces": ["apps/*", "packages/*"],
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:mcp": "turbo -F @discord-widgets/mcp-server dev",
		"check": "biome check --write .",
		"generate": "tsx scripts/generate-widget.ts",
		"gen": "tsx scripts/generate-widget.ts"
	},
	"dependencies": {
		"@discord-widgets/env": "workspace:*",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@discord-widgets/config": "workspace:*",
		"@biomejs/biome": "^2.4.16",
		"@types/node": "catalog:",
		"tsx": "^4.19.2",
		"turbo": "^2.9.16",
		"typescript": "catalog:"
	},
	"packageManager": "pnpm@10.32.1"
}
